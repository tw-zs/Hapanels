    <string name="app_name" translatable="false">Hapanels</string>

    <!-- ────────────────────────────────────────────────────────────────
         Translation policy

         User-visible chrome (top bars, dialog buttons, common labels,
         empty states) goes here so a translator can hit them in one
         file. Dev-menu strings, R1Log messages, and the literal entity
         IDs used by HA stay inline; they're for power users or never
         visible. Mark a string `translatable="false"` if it's a proper
         noun (the app name, the HA brand) or an identifier we ship
         verbatim regardless of locale.

         Convention: keys are snake_case grouped by surface, e.g.
         dialog_cancel, dialog_ok, chrome_settings, today_title.
         Strings that already have a unique technical key (shortcut_*,
         widget_*, quick_tile_*) keep theirs for back-compat with the
         manifest references that point at them.
        ──────────────────────────────────────────────────────────────── -->

    <!-- App-shortcut labels — surfaced when the user long-presses the
         launcher icon. Each routes through MainActivity's extras-based
         deep-link to a specific top-level surface; the short label
         appears in the launcher pop-up under the icon, the long label
         is read by accessibility services. -->
    <string name="shortcut_search_short">Search</string>
    <string name="shortcut_search_long">Quick Search across HA entities</string>
