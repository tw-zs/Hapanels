<?xml version="1.0" encoding="utf-8"?>
<!--
  AppWidget metadata for the R1HA quick-launch widget. Targets a single-cell
  square so the user can tuck it into any home-screen gap; resizable to a
  wider rectangle for users who prefer a more legible label. updatePeriodMillis
  is 0 because Android clamps below 30 min anyway and we only need to repaint
  on tap (the widget is a launcher shortcut, not a live data tile).
-->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:minWidth="40dp"
    android:minHeight="40dp"
    android:targetCellWidth="1"
    android:targetCellHeight="1"
    android:updatePeriodMillis="0"
    android:initialLayout="@layout/r1ha_widget"
    android:previewImage="@mipmap/ic_launcher"
    android:resizeMode="horizontal|vertical"
    android:widgetCategory="home_screen"
    android:description="@string/widget_description"/>
