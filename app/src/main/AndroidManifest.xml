<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <uses-permission android:name="android.permission.INTERNET"/>
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE"/>
    <uses-permission android:name="android.permission.WAKE_LOCK"/>
    <uses-permission android:name="android.permission.WRITE_SETTINGS"/>
    <uses-permission android:name="android.permission.VIBRATE"/>
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>
    <!-- Microphone access for the voice satellite. Requested at runtime when
         the user opens the satellite screen; we never record outside that
         surface, and the surface itself shows a permission rationale dialog
         before triggering the system prompt. -->
    <uses-permission android:name="android.permission.RECORD_AUDIO"/>
    <uses-feature android:name="android.hardware.microphone" android:required="false"/>

    <!-- NFC reading. Optional hardware: the NFC features still work when
         present but we don't require it, so the app installs on phones
         and tablets that don't ship with an NFC controller. -->
    <uses-permission android:name="android.permission.NFC"/>
    <uses-feature android:name="android.hardware.nfc" android:required="false"/>

    <!-- BLE peripheral advertising (iBeacon). BLUETOOTH_ADVERTISE is the
         Android-12+ runtime permission; the legacy BLUETOOTH permission
         is needed for older API levels. neverForLocation tells the OS we
         only advertise, never scan, so we don't need fine-location too. -->
    <uses-permission
        android:name="android.permission.BLUETOOTH_ADVERTISE"
        android:usesPermissionFlags="neverForLocation"
        tools:targetApi="31"/>
    <uses-permission android:name="android.permission.BLUETOOTH"
        android:maxSdkVersion="30"/>
    <uses-feature
        android:name="android.hardware.bluetooth_le"
        android:required="false"/>
    <!-- Required for Android 13+ to post the HA persistent-notification mirror.
         Users opt in via the toggle under Advanced; we only request the runtime
         permission when they enable the mirror, so installs that don't use the
         feature never see the prompt. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <!-- Foreground service to host the webhook listener. Required on Android
         8+ for any indefinitely-running socket holder; the service shows a
         persistent notification so the user knows why we're staying alive. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE"/>
    <uses-permission
        android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC"
        tools:targetApi="34"/>
    <!-- Needed for the in-app self-update flow: after we download a newer APK from
         GitHub Releases we fire ACTION_VIEW with a content:// URI, which Android's
         PackageInstaller honours only when the source app holds this permission.
         The user still has to confirm the install in the OS prompt — we never
         silently install. -->
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES"/>
    <!-- Resolve other apps that can handle ACTION_VIEW for our APK content URI
         (i.e. the package installer). On Android 11+ the system requires this
         declaration before queryIntentActivities returns anything useful. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.VIEW"/>
            <data android:mimeType="application/vnd.android.package-archive"/>
        </intent>
    </queries>

    <!-- Declare support for all screen sizes so OEM tablet shells (Samsung DeX,
         Xiaomi Pad, etc.) don't apply their own portrait-phone letterbox compat
         mode. Without this, some builds ignore android:resizeableActivity and
         show the app as a small phone-sized island on large screens. -->
    <supports-screens
        android:smallScreens="true"
        android:normalScreens="true"
        android:largeScreens="true"
        android:xlargeScreens="true"
        android:resizeable="true" />

    <application
        android:name=".App"
        android:label="@string/app_name"
        android:allowBackup="false"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:localeConfig="@xml/locales_config"
        android:networkSecurityConfig="@xml/network_security_config"
        android:supportsRtl="true"
        android:theme="@style/Theme.R1ha">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:resizeableActivity="true"
            android:configChanges="orientation|screenSize|smallestScreenSize|screenLayout|density|uiMode">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data android:scheme="r1ha" android:host="auth-callback"/>
            </intent-filter>
            <!-- App-shortcut definitions for the launcher pop-up. The
                  four shortcuts (Search / Assist / Panel grid / Automations)
                 launch MainActivity with an 'initial_route' extra that
                 the activity reads on resume and routes through the
                 existing nav graph. -->
            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
        </activity>
        <!-- Quick Settings tiles — mirror up to four HA entities' on/off state in
             the Android notification-shade Quick Settings panel. Each tile binds
             to a separate entity_id slot in Settings → BEHAVIOUR; slot A is the
             legacy default, B/C/D expose extra bindings for users with more than
             one "tile-worthy" entity. Each tile needs its own TileService class
             because Android binds tiles by class name. -->
        <service
            android:name=".feature.quicktile.HaQuickTileService"
            android:exported="true"
            android:icon="@mipmap/ic_launcher"
            android:label="@string/quick_tile_label"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE"/>
            </intent-filter>
            <meta-data
                android:name="android.service.quicksettings.ACTIVE_TILE"
                android:value="false"/>
        </service>
        <service
            android:name=".feature.quicktile.HaQuickTileServiceB"
            android:exported="true"
            android:icon="@mipmap/ic_launcher"
            android:label="@string/quick_tile_label_b"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE"/>
            </intent-filter>
            <meta-data
                android:name="android.service.quicksettings.ACTIVE_TILE"
                android:value="false"/>
        </service>
        <service
            android:name=".feature.quicktile.HaQuickTileServiceC"
            android:exported="true"
            android:icon="@mipmap/ic_launcher"
            android:label="@string/quick_tile_label_c"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE"/>
            </intent-filter>
            <meta-data
                android:name="android.service.quicksettings.ACTIVE_TILE"
                android:value="false"/>
        </service>
        <service
            android:name=".feature.quicktile.HaQuickTileServiceD"
            android:exported="true"
            android:icon="@mipmap/ic_launcher"
            android:label="@string/quick_tile_label_d"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE">
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE"/>
            </intent-filter>
            <meta-data
                android:name="android.service.quicksettings.ACTIVE_TILE"
                android:value="false"/>
        </service>

        <!-- Webhook listener foreground service. Opens a configurable TCP port
             (default 8765) so HA can POST automation webhooks at the device.
             Off until the user opts in under Dev menu > WEBHOOK. -->
        <service
            android:name=".core.webhook.WebhookListenerService"
            android:exported="false"
            android:foregroundServiceType="dataSync"/>

        <!-- Background-refresh JobService. Wakes the app every ~15 min (subject to
             Doze) and warms the HA entity cache via /api/states. Opt-in via the
             Advanced setting; never scheduled by default to avoid the battery hit
             on users who never see the benefit. -->
        <service
            android:name=".core.background.BackgroundRefreshJob"
            android:exported="false"
            android:permission="android.permission.BIND_JOB_SERVICE"/>

        <!-- Home-screen widget — a single-tile quick-launch shortcut. Tap opens
             MainActivity. No live data binding (RemoteViews + Doze would fight),
             so think of this as a launcher tile with the app's iconography. -->
        <receiver
            android:name=".feature.widget.R1haWidgetProvider"
            android:exported="true">
            <intent-filter>
                <action android:name="android.appwidget.action.APPWIDGET_UPDATE"/>
            </intent-filter>
            <meta-data
                android:name="android.appwidget.provider"
                android:resource="@xml/r1ha_widget_info"/>
        </receiver>

        <!-- DISMISS-action receiver for the HA notification mirror. Fired when the
             user taps the DISMISS button on a mirrored notification; routes to
             persistent_notification.dismiss via the existing repository. -->
        <receiver
            android:name=".core.notifications.HaNotificationMirror$DismissActionReceiver"
            android:exported="false">
            <intent-filter>
                <action android:name="com.github.itskenny0.r1ha.action.DISMISS_HA_NOTIF"/>
            </intent-filter>
        </receiver>

        <!-- External-automation broadcast receiver. Lets Tasker / MacroDroid /
             Automate fire HA service calls through our already-configured client
             by broadcasting the action below with ha_domain + ha_service extras.
             Exported so cross-app intents reach us; the receiver itself rejects
             the broadcast unless the user has enabled the opt-in toggle under
             Advanced settings, so a fresh install can't be hijacked. -->
        <receiver
            android:name=".core.extern.AutomationReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.github.itskenny0.r1ha.action.HA_SERVICE_CALL"/>
            </intent-filter>
        </receiver>

        <!-- Boot autostart receiver. When enabled in Settings → Behaviour, the
             app relaunches itself after device boot (and after app updates).
             The receiver only fires when the user has explicitly opted in. -->
        <receiver
            android:name=".core.startup.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED"/>
                <action android:name="android.intent.action.MY_PACKAGE_REPLACED"/>
            </intent-filter>
        </receiver>

        <!-- FileProvider for the in-app update flow — exposes the downloaded APK
             from cache as a content:// URI that the package installer can read.
             Authority matches applicationId + ".updates" so it stays unique to
             this app even if installed alongside another build. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.updates"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/updates_paths"/>
        </provider>
    </application>
</manifest>
